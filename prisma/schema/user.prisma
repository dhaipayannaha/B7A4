model User {
    id       String  @id @default(cuid())
    name     String
    email    String  @unique
    password String
    phone    String?
    image    String?

    role   UserRole   @default(CUSTOMER)
    status UserStatus @default(ACTIVE)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    // gearItems GearItem[]
    // rentals   RentalOrder[]
    // reviews   Review[]

    @@map("users")
}
